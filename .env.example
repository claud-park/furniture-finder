# 쿠팡 파트너스 오픈API (https://partners.coupang.com → 추가수익 → Open API)
# 미설정 시 쿠팡 소스는 "미설정" 뱃지와 함께 자동 skip됩니다.
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# Google Programmable Search Engine (오늘의집/무인양품 우회 검색용)
# API 키: https://developers.google.com/custom-search/v1/introduction
# CX(검색엔진 ID): https://programmablesearchengine.google.com/ 에서 엔진 생성 후 확인
#   - 엔진 설정에서 "전체 웹 검색" 활성화 (site: 연산자로 도메인 제한)
GOOGLE_PSE_API_KEY=
GOOGLE_PSE_CX=
